{
  "name": "email-design-mcp",
  "version": "0.3.0",
  "description": "Design and generate responsive email templates with AI — MCP server for Claude, Cursor, VS Code Copilot. Brand-aware, MJML-powered, no API keys needed.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "email-design-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "email",
    "email-template",
    "email-design",
    "email-generator",
    "mjml",
    "responsive-email",
    "html-email",
    "ai",
    "claude",
    "cursor",
    "vscode",
    "copilot",
    "newsletter",
    "marketing-email",
    "transactional-email",
    "brand",
    "design-system",
    "no-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harikrishna8121999/email-design-mcp.git"
  },
  "homepage": "https://github.com/harikrishna8121999/email-design-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cheerio": "^1.2.0",
    "mjml": "^5.0.0-alpha.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
